# Google Custom Search JSON API
# Create a programmable search engine and enable Custom Search JSON API.
GOOGLE_API_KEY=your_google_custom_search_api_key
GOOGLE_CX=your_custom_search_engine_id

# Local deduplication database
SQLITE_PATH=processed_jobs.sqlite3
REQUEST_TIMEOUT_SECONDS=20
DRY_RUN=false

# Google Sheets tracking
# Share the sheet with your service account email.
SHEETS_ENABLED=false
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_NAME=Jobs
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# Alternative for hosted environments:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Telegram notifications
# Keep disabled for now if you only want the platform foundation.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Gemini AI fit review (local/export only, disabled by default to protect quota)
# Put the real key in .env only. Do not commit it.
GEMINI_ENABLED=false
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_DAILY_LIMIT=20
GEMINI_ON_CATEGORIES=review
GEMINI_MAX_INPUT_CHARS=6000
GEMINI_CACHE_PATH=gemini_fit_cache.sqlite3
